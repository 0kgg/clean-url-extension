{
  "manifest_version": 3,
  "name": "Clean URL Copier",
  "description": "拡張アイコンを押すとポップアップを表示し、現在タブのクリーンURLに加えて商品名・色・サイズ・単価・個数を編集してまとめてコピーできます。",
  "version": "0.2.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "action": {
    "default_title": "クリーンURLをコピー",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  }
}
